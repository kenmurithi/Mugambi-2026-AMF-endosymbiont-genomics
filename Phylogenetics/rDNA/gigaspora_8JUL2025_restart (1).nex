end;
begin mrbayes;

	charset ssu = 1-239;
	charset its1 = 240-342;
	charset S58 = 343-502;
	charset its2 = 503-708;
	charset lsu = 709-1500;


	partition all = 5: ssu,its1,S58,its2,lsu;
	set partition = all;

	lset applyto=(1,2,3,4,5) nst=6 rates=invgamma;

	unlink statefreq=(all) revmat=(all) shape=(all) pinvar=(all);

	prset applyto=(all) ratepr=variable;




	mcmcp samplefreq=1000 printfreq=1000;
	mcmcp nchains=8  stoprule=YES burninfrac=.25 stopval=0.01 minpartfreq=0.05;
	mcmcp savebrlens=yes filename= /home/francom/mrbayes_analysis/gigaspora2025_restart/gigaspora.nxs;
	mcmc append=yes ngen=40000000;	
	sumt filename= /home/francom/mrbayes_analysis/gigaspora2025_restart/gigaspora.nxs burninfrac=.30 contype=halfcompat;
	sump filename= /home/francom/mrbayes_analysis/gigaspora2025_restart/gigaspora.nxs burninfrac=.30 printtofile=yes;





END;